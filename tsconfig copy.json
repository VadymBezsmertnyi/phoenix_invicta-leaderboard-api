{
  "compilerOptions": {
    "target": "es2015",
    "module": "CommonJS",
    "lib": ["es6", "es2021"],
    "allowJs": true,
    "outDir": "build",
    "rootDir": "src",
    "strict": true,
    "sourceMap": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "compileOnSave": true,
  "exclude": ["node_modules", "build", "eslint.config.mjs"]
}
